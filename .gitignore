# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data (large files)
# NOTE: Small simulation .npy files (<10MB) are tracked
# Large empirical datasets are excluded
data/uci/*.csv
data/cdnow/*.csv
data/raw/

# Results (generated PKLs are large - exclude)
results/**/*.pkl
results/**/*.pkl.gz
results/**/smc_*.pkl
!results/.gitkeep

# Figures (generated - can be regenerated)
results/**/*.pdf
results/**/*.png
results/**/*.jpg
!results/figures/.gitkeep

# Logs
*.log
logs/

# Environment
.env
.conda

# PyMC/Tensorflow cache
.pymc/
.cache/


======================================================================
Save as: .gitignore
======================================================================
